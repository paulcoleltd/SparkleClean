# SparkleClean — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is git-ignored.
# Every new variable MUST be added here with a description.

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# Use the "Transaction mode" string (port 6543) — includes PgBouncer
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"


# Direct connection (no pooler) — used by Prisma for migrations only
# Use the "Direct connection" string (port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"



# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Must verify sparkleclean.com domain before sending from bookings@sparkleclean.com
RESEND_API_KEY="re_..."

# ─── Authentication (NextAuth.js v5) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Rotate immediately if ever committed to git
AUTH_SECRET="<random-32-char-string>"

# The canonical URL of your deployment (no trailing slash)
# Development: http://localhost:3000
# Production: https://sparkleclean.com
AUTH_URL="http://localhost:3000"

# ─── Admin Seed (used by prisma/seed.ts only) ─────────────────────────────────
# Password for the initial admin account created by the seed script
# Remove from production env after seeding
ADMIN_SEED_PASSWORD="<strong-password-min-12-chars>"

# ─── App ──────────────────────────────────────────────────────────────────────
# Safe to expose to browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="SparkleClean"
NEXT_PUBLIC_COMPANY_EMAIL="info@sparkleclean.com"
NEXT_PUBLIC_COMPANY_PHONE="+44 20 7946 0958"

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Vercel sets Authorization: Bearer <CRON_SECRET> automatically when invoking cron routes.
# Generate with: openssl rand -base64 32
CRON_SECRET="<random-32-char-string>"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_...) during development
STRIPE_SECRET_KEY="sk_test_..."

# Webhook secret — get from: Stripe dashboard → Webhooks → your endpoint → Signing secret
# For local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public key — safe to expose to browser (not currently used but good to have)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Optional: leave empty to use the in-memory rate limiter (fine for single-instance/dev).
# Required for multi-instance deployments (e.g. Vercel with >1 serverless instance).
# Get from: console.upstash.com → Create Database → REST API section
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Error monitoring (Sentry) ────────────────────────────────────────────────
# Optional: leave empty to disable Sentry (errors still logged to console).
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is used client-side.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Required at build time to upload source maps to Sentry (CI only).
# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
