# SparkleClean — E2E Test Environment
# Used by: playwright.config.ts + e2e/global-setup.ts
# This file is safe to commit — it uses local Docker credentials only.
# Copy to .env.test.local to override for your machine.
#
# Prerequisites:
#   docker compose up -d   (starts local PostgreSQL on port 5433)

# ─── Database — local Docker PostgreSQL ──────────────────────────────────────
DATABASE_URL="postgresql://sparkle:sparkle@localhost:5433/sparkleclean?connection_limit=1"
DIRECT_URL="postgresql://sparkle:sparkle@localhost:5433/sparkleclean"

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="test-e2e-secret-not-for-production-32ch"
AUTH_URL="http://localhost:3000"

# ─── Admin test account ───────────────────────────────────────────────────────
# Seeded by e2e/global-setup.ts
ADMIN_SEED_PASSWORD="TestAdmin123!"
ADMIN_SEED_EMAIL="admin@sparkleclean.com"

# ─── Email — disabled in E2E tests ────────────────────────────────────────────
# RESEND_API_KEY left blank so Resend client is initialised but calls fail gracefully
# emailService catches errors non-blocking, so tests are not affected
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_DEV_TO="paulcoleltd@gmail.com,kmintsltd@gmail.com"

# ─── Stripe — test mode keys ──────────────────────────────────────────────────
# E2E tests mock the /api/bookings response so Stripe is never called.
# Set real sk_test_... keys here if you want to test the actual Stripe redirect.
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_KEY"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="SparkleClean"
NEXT_PUBLIC_COMPANY_EMAIL="info@sparkleclean.com"
NEXT_PUBLIC_COMPANY_PHONE="+44 20 7946 0958"

# ─── SMS (Twilio) — disabled in tests ────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── Cron / Rate limiting / Sentry — disabled in tests ───────────────────────
CRON_SECRET="test-cron-secret"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
